      "name": "AUTH - Logins",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.globals.set('token-admin', jsonData.token);",
                  "    pm.globals.set('adminId', jsonData.usuario?.id || 1);",
                  "    console.log('✅ Token Admin guardado: ' + jsonData.token.substring(0,20) + '...');",
                  "} else {",
                  "    console.log('❌ No se pudo guardar token. Respuesta:', jsonData);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"correo\":\"admin@test.com\",\"contrasena\":\"12345678\"}"
            },
            "url": {
              "raw": "http://localhost:3000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "auth", "login"]
            }
          }
